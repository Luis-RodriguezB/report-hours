{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "registro-horas-app",
  "version": "0.1.1",
  "identifier": "com.lrodr.registro-horas-app",

  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwNEY3OTMzRTE3NDdBRTAKUldUZ2VuVGhNM2xQRVA3NkFlMnNWU3hxNUFiUTFHNCtpMWVneTVCM0pRUi9vNWxQL1lQWEM2SjQK",
      "endpoints": [
        "https://github.com/Luis-RodriguezB/report-hours/releases/latest/download/latest.json"
      ]
    }
  },

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },

  "app": {
