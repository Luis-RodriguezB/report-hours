{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "registro-horas-app",
  "version": "0.1.1",
  "identifier": "com.lrodr.registro-horas-app",

  "plugins": {
    "updater": {
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBRENCOTVDOEZDREE3QTIKUldTaXA4MlBYTG5jNnBSREhLaUlLSHpFUFZ5N25ldit3dDkrUkE4RUJYdWdQL2NjdVgxM0hHaEsK",
      "endpoints": [
        "https://github.com/Luis-RodriguezB/report-hours/releases/latest/download/latest.json"
      ]
    }
  },

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "Registro de Horas",
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
